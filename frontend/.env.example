# Frontend API key
# 백엔드 SECURITY_API_KEY와 동일한 값을 사용하세요.
VITE_API_KEY=your-api-key-here

# Google Identity Services client ID
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# 선택 사항: 허용할 Google 로그인 접속 주소 목록(쉼표 구분)
# 비워 두면 개발 환경에서는 localhost/127.0.0.1 기본 주소를 자동 허용합니다.
VITE_GOOGLE_ALLOWED_ORIGINS=

# Billing / subscription UI toggle
# 현재는 결제 기능을 비활성화하는 것이 기본값입니다.
VITE_BILLING_ENABLED=false
